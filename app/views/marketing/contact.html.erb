<section class="max-w-5xl mx-auto px-6 py-16">
  <h1 class="text-3xl font-secondary text-[var(--clr-primary-a10)] mb-4">Contact Us</h1>
  <form class="space-y-4">
    <input type="text" placeholder="Your Name" class="w-full rounded-md bg-[var(--clr-surface-a20)] px-3 py-2" />
    <input type="email" placeholder="Your Email" class="w-full rounded-md bg-[var(--clr-surface-a20)] px-3 py-2" />
    <textarea rows="5" placeholder="Your Message" class="w-full rounded-md bg-[var(--clr-surface-a20)] px-3 py-2"></textarea>
    <button type="submit" class="bg-[var(--clr-primary-a0)] text-[var(--clr-light-a0)] px-4 py-2 rounded-md hover:bg-[var(--clr-primary-a20)]">Send Message</button>
  </form>
</section>
