<footer class="bg-[var(--clr-surface-a20)] border-t border-[var(--clr-surface-a40)] text-[var(--clr-primary-a40)] mt-auto">
  <div class="mx-auto max-w-7xl px-6 py-8 lg:px-8">
    <!-- Newsletter Section -->
    <div class="flex flex-col items-center justify-between gap-6 border-b border-[var(--clr-surface-a40)] pb-6 sm:flex-row">
      <div>
        <h3 class="text-sm font-semibold text-[var(--clr-primary-a10)]">Subscribe to our newsletter</h3>
        <p class="mt-1 text-sm text-[var(--clr-primary-a40)]">The latest news, articles, and resources, sent to your inbox weekly.</p>
      </div>
      <form class="w-full sm:w-auto sm:flex sm:max-w-md">
        <label for="email-address" class="sr-only">Email address</label>
        <input
          id="email-address"
          type="email"
          name="email-address"
          required
          placeholder="Enter your email"
          autocomplete="email"
          class="w-full min-w-0 rounded-md bg-[var(--clr-surface-a30)] px-3 py-1.5 text-sm text-[var(--clr-light-a0)] placeholder:text-[var(--clr-surface-a50)] focus:outline focus:outline-2 focus:-outline-offset-2 focus:outline-[var(--clr-primary-a30)] sm:w-56"
        />
        <div class="mt-3 sm:mt-0 sm:ml-4 sm:shrink-0">
          <button
            type="submit"
            class="flex w-full items-center justify-center rounded-md bg-[var(--clr-primary-a0)] px-3 py-2 text-sm font-semibold text-[var(--clr-light-a0)] shadow hover:bg-[var(--clr-primary-a20)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--clr-primary-a10)]"
          >
            Subscribe
          </button>
        </div>
      </form>
    </div>

    <!-- Copyright + Social Links -->
    <div class="mt-6 flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-sm text-[var(--clr-primary-a40)]">&copy; 2025 Star Synk. All rights reserved.</p>
      <div class="flex gap-x-5">
        <!-- X -->
        <%= link_to "#", class: "hover:text-[var(--clr-primary-a10)]", title: "X" do %>
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="size-5 fill-[var(--clr-primary-a40)] hover:fill-[var(--clr-primary-a10)]">
            <path d="M13.6823 10.6218L20.2391 3H18.6854L12.9921 9.61788L8.44486 3H3.2002L10.0765 13.0074L3.2002 21H4.75404L10.7663 14.0113L15.5685 21H20.8131L13.6819 10.6218H13.6823ZM11.5541 13.0956L10.8574 12.0991L5.31391 4.16971H7.70053L12.1742 10.5689L12.8709 11.5655L18.6861 19.8835H16.2995L11.5541 13.096V13.0956Z"/>
          </svg>
        <% end %>

        <!-- GitHub -->
        <%= link_to "#", class: "hover:text-[var(--clr-primary-a10)]", title: "GitHub" do %>
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="size-5 fill-[var(--clr-primary-a40)] hover:fill-[var(--clr-primary-a10)]">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        <% end %>

        <!-- YouTube -->
        <%= link_to "#", class: "hover:text-[var(--clr-primary-a10)]", title: "YouTube" do %>
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="size-5 fill-[var(--clr-primary-a40)] hover:fill-[var(--clr-primary-a10)]">
            <path fill-rule="evenodd" clip-rule="evenodd" d="M19.812 5.418c.861.23 1.538.907 1.768 1.768C21.998 8.746 22 12 22 12s0 3.255-.418 4.814a2.504 2.504 0 0 1-1.768 1.768c-1.56.419-7.814.419-7.814.419s-6.255 0-7.814-.419a2.505 2.505 0 0 1-1.768-1.768C2 15.255 2 12 2 12s0-3.255.417-4.814a2.507 2.507 0 0 1 1.768-1.768C5.744 5 11.998 5 11.998 5s6.255 0 7.814.418ZM15.194 12 10 15V9l5.194 3Z"/>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</footer>


